#Experiment0[0] |= $NoKnockDowns "no knockdowns";
#Experiment0[0] |= $NoOverExpression "no overexpression";
#Experiment0[15] |= $FIN0 "final state";

$INIT0 := {
  v_Coup_fti = 1 and
  v_Emx2 = 0 and
  v_Fgf8 = 0 and
  v_Pax6 = 1 and
  v_Sp8 = 0
};

$FIN0 := {
