// Synchronous dynamics
directive updates sync;

// Default regulation conditions
directive regulation legacy;

v_Coup_fti[-+] (0..17); v_Emx2[-+] (0..17); v_Fgf8[-+] (0..17); v_Pax6[-+] (0..17); v_Sp8[-+] (0..17);

v_Sp8 v_Emx2 negative;
v_Coup_fti v_Emx2 positive;
v_Pax6 v_Emx2 negative;
v_Fgf8 v_Emx2 negative;
v_Emx2 v_Sp8 negative;
v_Fgf8 v_Sp8 positive;
v_Sp8 v_Coup_fti negative;
v_Fgf8 v_Coup_fti negative;
v_Sp8 v_Pax6 positive;
v_Coup_fti v_Pax6 negative;
v_Emx2 v_Pax6 negative;
v_Sp8 v_Fgf8 positive;
v_Emx2 v_Fgf8 negative;
v_Fgf8 v_Fgf8 positive;


